page {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

view, text, button, input, textarea {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

button::after {
  border: none;
}