.card-display {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx;
}

.card-wrapper {
  width: 560rpx;
  padding: 48rpx;
  border-radius: 32rpx;
  text-align: center;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.4);
}

.card-wrapper.chance {
  background: linear-gradient(135deg, #9C27B0 0%, #7B1FA2 100%);
}

.card-wrapper.fate {
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
}

.card-type-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
}

.card-icon {
  margin-bottom: 32rpx;
}

.card-icon text {
  font-size: 96rpx;
}

.card-title {
  display: block;
  font-size: 48rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.card-description {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}
