.game-board {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: radial-gradient(circle at center, rgba(255,255,255,0.05) 0%, transparent 70%);
}

.board-container {
  position: relative;
  width: 2080rpx;
  height: 1440rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.notification-overlay {
  position: absolute;
  top: 15%;
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
  pointer-events: none;
}

.auction-success-message {
  padding: 40rpx 80rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 30%, #FF8C00 60%, #FFD700 100%);
  background-size: 200% 200%;
  border-radius: 48rpx;
  color: #1a1a2e;
  font-weight: 800;
  font-size: 48rpx;
  box-shadow:
    0 20rpx 80rpx rgba(255, 215, 0, 0.6),
    0 0 120rpx rgba(255, 215, 0, 0.4),
    0 0 200rpx rgba(255, 215, 0, 0.2),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.8),
    inset 0 -2rpx 0 rgba(0, 0, 0, 0.1);
  animation:
    auction-success-pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1),
    auction-success-glow 2s ease-in-out infinite,
    auction-success-shimmer 3s linear infinite;
  white-space: nowrap;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  position: relative;
  overflow: hidden;
  text-shadow: 0 4rpx 8rpx rgba(255, 255, 255, 0.5);
  letter-spacing: 2rpx;
}

.auction-success-message::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.4) 50%,
    transparent 100%);
  animation: auction-success-shine 2s ease-in-out infinite;
}

.auction-success-message::after {
  content: '🎉';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  font-size: 64rpx;
  animation: party-popper 0.5s ease-out;
}

@keyframes auction-success-pop {
  0% { opacity: 0; transform: scale(0.3) translateY(100rpx) rotate(-10deg); }
  30% { transform: scale(1.15) translateY(-20rpx) rotate(5deg); }
  50% { transform: scale(0.95) translateY(0) rotate(-2deg); }
  70% { transform: scale(1.02) translateY(-4rpx) rotate(1deg); }
  100% { opacity: 1; transform: scale(1) translateY(0) rotate(0deg); }
}

@keyframes auction-success-glow {
  0%, 100% {
    box-shadow:
      0 20rpx 80rpx rgba(255, 215, 0, 0.6),
      0 0 120rpx rgba(255, 215, 0, 0.4),
      0 0 200rpx rgba(255, 215, 0, 0.2),
      inset 0 2rpx 0 rgba(255, 255, 255, 0.8),
      inset 0 -2rpx 0 rgba(0, 0, 0, 0.1);
  }
  50% {
    box-shadow:
      0 30rpx 100rpx rgba(255, 215, 0, 0.8),
      0 0 160rpx rgba(255, 215, 0, 0.6),
      0 0 240rpx rgba(255, 215, 0, 0.4),
      inset 0 2rpx 0 rgba(255, 255, 255, 0.9),
      inset 0 -2rpx 0 rgba(0, 0, 0, 0.15);
  }
}

@keyframes auction-success-shimmer {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes auction-success-shine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

@keyframes party-popper {
  0% { opacity: 0; transform: scale(0) rotate(0deg); }
  50% { opacity: 1; transform: scale(1.5) rotate(180deg); }
  100% { opacity: 1; transform: scale(1) rotate(360deg); }
}

.dice-center-container {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  z-index: 50;
}

.btn-center-dice {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 32rpx 56rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(30rpx);
  border: 6rpx solid var(--player-color, rgba(255, 255, 255, 0.5));
  border-radius: 32rpx;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.2), 0 0 40rpx var(--player-color, rgba(255, 255, 255, 0.3));
}

.btn-center-dice:active {
  transform: scale(0.98);
}

.dice-icon {
  font-size: 72rpx;
  animation: dice-bounce 2s ease-in-out infinite;
}

@keyframes dice-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.btn-center-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 12rpx 32rpx;
  background: rgba(156, 39, 176, 0.25);
  backdrop-filter: blur(20rpx);
  border: 3rpx solid rgba(156, 39, 176, 0.5);
  border-radius: 32rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(156, 39, 176, 0.2);
}

.btn-center-item:active {
  transform: scale(0.98);
}

.item-icon {
  font-size: 28rpx;
}

.item-text {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
}

.dice-text {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.4);
}

.current-player-indicator {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 32rpx;
  background: var(--player-color, rgba(255, 215, 0, 0.25));
  opacity: 0.85;
  backdrop-filter: blur(20rpx);
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx var(--player-color, rgba(255, 215, 0, 0.3));
}

.current-player-indicator .player-name {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.current-player-indicator .turn-badge {
  font-size: 20rpx;
  font-weight: 600;
  color: #ffd700;
  background: rgba(255, 215, 0, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.board-row {
  display: flex;
  gap: 10rpx;
}

.tile {
  width: 150rpx;
  height: 150rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.15);
}

.tile:active {
  transform: scale(1.06) translateY(-6rpx);
  z-index: 10;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.25);
}

.tile.empty {
  background: transparent;
  border: none;
  box-shadow: none;
}

.tile.start {
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.5) 0%, transparent 50%),
    linear-gradient(225deg, rgba(255, 215, 0, 0.3) 0%, transparent 50%),
    linear-gradient(135deg, #FFF8E1 0%, #FFECB3 30%, #FFD54F 60%, #FFC107 100%);
  border: 8rpx solid #FFA000;
  background-size: 100% 100%, 100% 100%, 100% 100%;
}

.tile.start::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 16rpx,
    rgba(255, 255, 255, 0.2) 16rpx,
    rgba(255, 255, 255, 0.2) 20rpx
  );
  border-radius: 20rpx;
  pointer-events: none;
}

.tile.property {
  background: linear-gradient(135deg, #E0E0E0 0%, #BDBDBD 100%);
}

.tile.property.owned {
  border-color: #FFD700;
}

.tile.property.selectable {
  animation: selectable-pulse 1s ease-in-out infinite;
  border-color: #FFD700;
  border-width: 6rpx;
  border-style: solid;
  z-index: 20;
}

@keyframes selectable-pulse {
  0%, 100% {
    box-shadow:
      0 0 30rpx rgba(255, 215, 0, 0.6),
      0 0 60rpx rgba(255, 215, 0, 0.4),
      0 0 90rpx rgba(255, 215, 0, 0.2);
    transform: scale(1);
    border-color: #FFD700;
  }
  50% {
    box-shadow:
      0 0 50rpx rgba(255, 215, 0, 1),
      0 0 100rpx rgba(255, 215, 0, 0.7),
      0 0 150rpx rgba(255, 215, 0, 0.4);
    transform: scale(1.08);
    border-color: #FFEB3B;
  }
}

.tile.chance {
  background:
    radial-gradient(circle at 0% 0%, rgba(255, 128, 171, 0.4) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(255, 182, 193, 0.2) 0%, transparent 40%),
    linear-gradient(135deg, #FAFAFA 0%, #F5F5F5 50%, #EEEEEE 100%);
  border: 6rpx solid #FF80AB;
  box-shadow:
    0 0 30rpx rgba(255, 128, 171, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
  background-size: 100% 100%, 100% 100%, 100% 100%;
}

.tile.fate {
  background:
    radial-gradient(circle at 100% 100%, rgba(123, 31, 162, 0.4) 0%, transparent 50%),
    radial-gradient(circle at 20% 20%, rgba(156, 39, 176, 0.2) 0%, transparent 40%),
    linear-gradient(135deg, #FAFAFA 0%, #F5F5F5 50%, #EEEEEE 100%);
  border: 6rpx solid #7B1FA2;
  box-shadow:
    0 0 30rpx rgba(123, 31, 162, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
  background-size: 100% 100%, 100% 100%, 100% 100%;
}

.tile.station {
  background:
    linear-gradient(135deg, #FAFFFF 0%, #F0FCFD 30%, #E0F7FA 60%, #B2EBF2 100%);
  border: 6rpx solid #80DEEA;
  box-shadow:
    0 0 30rpx rgba(0, 172, 193, 0.25),
    0 10rpx 24rpx rgba(0, 0, 0, 0.1),
    inset 0 4rpx 8rpx rgba(255, 255, 255, 0.9),
    inset 0 -2rpx 4rpx rgba(0, 172, 193, 0.1);
}

.tile.station::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 12rpx;
  right: 12rpx;
  height: 6rpx;
  background: repeating-linear-gradient(
    90deg,
    rgba(0, 172, 193, 0.6) 0px,
    rgba(0, 172, 193, 0.6) 10rpx,
    transparent 10rpx,
    transparent 18rpx
  );
  transform: translateY(-50%);
  border-radius: 3rpx;
  pointer-events: none;
}

.tile.jail {
  background:
    repeating-linear-gradient(
      0deg,
      rgba(158, 158, 158, 0.3) 0px,
      rgba(158, 158, 158, 0.3) 8rpx,
      rgba(255, 255, 255, 0.1) 8rpx,
      rgba(255, 255, 255, 0.1) 16rpx
    ),
    linear-gradient(135deg, #EFEFEF 0%, #DEDEDE 30%, #E8E8E8 70%, #E0E0E0 100%);
  border: 6rpx solid #757575;
  box-shadow:
    0 0 36rpx rgba(117, 117, 117, 0.35),
    0 10rpx 24rpx rgba(0, 0, 0, 0.12),
    inset 0 4rpx 8rpx rgba(255, 255, 255, 0.7),
    inset 0 -4rpx 8rpx rgba(117, 117, 117, 0.15);
  background-size: 100% 100%, 100% 100%;
}

.tile.jail::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 50%),
    linear-gradient(225deg, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
  border-radius: 22rpx;
  pointer-events: none;
}

.tile.hall {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.5) 0%, transparent 50%),
    linear-gradient(135deg, #FAFAFA 0%, #F5F5F5 50%, #FAFAFA 100%);
  border: 6rpx solid #BDBDBD;
  box-shadow:
    0 10rpx 20rpx rgba(0, 0, 0, 0.15),
    0 20rpx 50rpx rgba(0, 0, 0, 0.1),
    inset 0 4rpx 6rpx rgba(255, 255, 255, 0.8);
  background-size: 100% 100%, 100% 100%;
}

.tile.hall .tile-icon {
  filter:
    drop-shadow(0 6rpx 8rpx rgba(0, 0, 0, 0.5))
    drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.3));
  text-shadow:
    0 4rpx 8rpx rgba(0, 0, 0, 0.4),
    0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.tile.casino {
  background:
    radial-gradient(circle at 50% 50%, rgba(244, 67, 54, 0.25) 0%, transparent 60%),
    radial-gradient(circle at 20% 80%, rgba(233, 30, 99, 0.15) 0%, transparent 40%),
    linear-gradient(135deg, #FAFAFA 0%, #F5F5F5 50%, #EEEEEE 100%);
  border: 6rpx solid #F44336;
  box-shadow:
    0 0 30rpx rgba(244, 67, 54, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
  background-size: 100% 100%, 100% 100%, 100% 100%;
}

.tile.shop {
  background:
    linear-gradient(135deg, #EFEBE9 0%, #D7CCC8 30%, #BCAAA4 60%, #A1887F 100%);
  border: 6rpx solid #8D6E63;
  box-shadow:
    0 0 36rpx rgba(141, 110, 99, 0.4),
    0 10rpx 24rpx rgba(0, 0, 0, 0.12),
    inset 0 4rpx 8rpx rgba(255, 255, 255, 0.85),
    inset 0 -2rpx 4rpx rgba(161, 136, 127, 0.2);
}

.tile.shop::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  background-image:
    linear-gradient(45deg, rgba(255, 255, 255, 0.35) 25%, transparent 25%),
    linear-gradient(-45deg, rgba(255, 255, 255, 0.35) 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, rgba(255, 255, 255, 0.35) 75%),
    linear-gradient(-45deg, transparent 75%, rgba(255, 255, 255, 0.35) 75%);
  background-size: 24rpx 24rpx;
  background-position: 0 0, 0 12rpx, 12rpx -12rpx, -12rpx 0px;
  border-radius: 16rpx;
  pointer-events: none;
}

.tile.auction {
  background:
    linear-gradient(135deg, #EFEBE9 0%, #D7CCC8 25%, #BCAAA4 50%, #A1887F 75%, #8D6E63 100%);
  border: 6rpx solid #5D4037;
  box-shadow:
    0 0 36rpx rgba(93, 64, 55, 0.4),
    0 10rpx 24rpx rgba(0, 0, 0, 0.15),
    inset 0 4rpx 8rpx rgba(255, 255, 255, 0.6),
    inset 0 -4rpx 8rpx rgba(93, 64, 55, 0.2);
}

.tile.auction::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  height: 8rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.5) 30%,
    rgba(255, 255, 255, 0.7) 50%,
    rgba(255, 255, 255, 0.5) 70%,
    transparent 100%);
  border-radius: 12rpx 12rpx 0 0;
  pointer-events: none;
}

.tile.property.auctioning {
  animation: auction-glow 1s ease-in-out infinite;
  border-color: #FFD700;
  border-width: 10rpx;
  border-style: solid;
  box-shadow:
    0 0 50rpx rgba(255, 215, 0, 1),
    0 0 100rpx rgba(255, 200, 0, 0.8),
    0 0 150rpx rgba(255, 180, 0, 0.6),
    0 0 200rpx rgba(255, 150, 0, 0.4);
  z-index: 50;
}

@keyframes auction-glow {
  0%, 100% {
    box-shadow:
      0 0 50rpx rgba(255, 215, 0, 1),
      0 0 100rpx rgba(255, 200, 0, 0.8),
      0 0 150rpx rgba(255, 180, 0, 0.6),
      0 0 200rpx rgba(255, 150, 0, 0.4);
    transform: scale(1);
    filter: brightness(1);
  }
  50% {
    box-shadow:
      0 0 80rpx rgba(255, 255, 100, 1),
      0 0 160rpx rgba(255, 230, 50, 0.9),
      0 0 240rpx rgba(255, 200, 0, 0.7),
      0 0 320rpx rgba(255, 150, 0, 0.5);
    transform: scale(1.1);
    filter: brightness(1.2);
  }
}

.tile.property.effect-upgrade {
  animation: upgrade-glow 0.5s ease-in-out infinite;
  z-index: 50;
}

@keyframes upgrade-glow {
  0%, 100% {
    box-shadow:
      0 0 30rpx rgba(0, 255, 100, 1),
      0 0 60rpx rgba(0, 255, 100, 0.8),
      0 0 90rpx rgba(0, 200, 80, 0.6);
    transform: scale(1);
  }
  50% {
    box-shadow:
      0 0 50rpx rgba(0, 255, 150, 1),
      0 0 100rpx rgba(0, 255, 150, 0.9),
      0 0 150rpx rgba(0, 200, 100, 0.7);
    transform: scale(1.08);
  }
}

.tile.property.effect-fire {
  animation: fire-glow 0.3s ease-in-out infinite;
  z-index: 50;
}

@keyframes fire-glow {
  0%, 100% {
    box-shadow:
      0 0 30rpx rgba(255, 100, 50, 1),
      0 0 60rpx rgba(255, 80, 30, 0.8),
      0 0 90rpx rgba(200, 50, 20, 0.6);
    transform: scale(1) rotate(0deg);
  }
  25% {
    box-shadow:
      0 0 40rpx rgba(255, 150, 50, 1),
      0 0 80rpx rgba(255, 100, 30, 0.9),
      0 0 120rpx rgba(200, 60, 20, 0.7);
    transform: scale(1.05) rotate(-2deg);
  }
  50% {
    box-shadow:
      0 0 50rpx rgba(255, 200, 100, 1),
      0 0 100rpx rgba(255, 150, 50, 0.9),
      0 0 150rpx rgba(200, 100, 30, 0.7);
    transform: scale(1.1) rotate(0deg);
  }
  75% {
    box-shadow:
      0 0 40rpx rgba(255, 150, 50, 1),
      0 0 80rpx rgba(255, 100, 30, 0.9),
      0 0 120rpx rgba(200, 60, 20, 0.7);
    transform: scale(1.05) rotate(2deg);
  }
}

.tile.property.effect-disaster {
  animation: disaster-shake 0.5s ease-in-out infinite;
  z-index: 50;
}

@keyframes disaster-shake {
  0%, 100% {
    box-shadow:
      0 0 30rpx rgba(150, 150, 150, 1),
      0 0 60rpx rgba(120, 120, 120, 0.8),
      0 0 90rpx rgba(100, 100, 100, 0.6);
    transform: translateX(0) translateY(0) rotate(0deg);
  }
  10% { transform: translateX(-6rpx) translateY(-4rpx) rotate(-1deg); }
  20% { transform: translateX(6rpx) translateY(4rpx) rotate(1deg); }
  30% { transform: translateX(-4rpx) translateY(-2rpx) rotate(-0.5deg); }
  40% { transform: translateX(4rpx) translateY(2rpx) rotate(0.5deg); }
  50% {
    box-shadow:
      0 0 50rpx rgba(200, 200, 200, 1),
      0 0 100rpx rgba(150, 150, 150, 0.9),
      0 0 150rpx rgba(120, 120, 120, 0.7);
    transform: translateX(-2rpx) translateY(-2rpx) rotate(-0.3deg);
  }
  60% { transform: translateX(2rpx) translateY(2rpx) rotate(0.3deg); }
  70% { transform: translateX(-4rpx) translateY(-2rpx) rotate(-0.5deg); }
  80% { transform: translateX(4rpx) translateY(2rpx) rotate(0.5deg); }
  90% { transform: translateX(-2rpx) translateY(-2rpx) rotate(-0.3deg); }
}

.tile.park {
  background:
    radial-gradient(circle at 0% 100%, rgba(76, 175, 80, 0.3) 0%, transparent 40%),
    radial-gradient(circle at 100% 0%, rgba(76, 175, 80, 0.25) 0%, transparent 35%),
    linear-gradient(135deg, #FAFAFA 0%, #F5F5F5 50%, #EEEEEE 100%);
  border: 6rpx solid #4CAF50;
  box-shadow:
    0 0 30rpx rgba(76, 175, 80, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
  background-size: 100% 100%, 100% 100%, 100% 100%;
}

.tile.fund {
  background:
    radial-gradient(circle at 50% 30%, rgba(255, 215, 0, 0.35) 0%, transparent 50%),
    linear-gradient(135deg, #FAFAFA 0%, #F5F5F5 50%, #EEEEEE 100%);
  border: 6rpx solid #FFC107;
  box-shadow:
    0 0 30rpx rgba(255, 193, 7, 0.3),
    0 10rpx 24rpx rgba(0, 0, 0, 0.1),
    inset 0 4rpx 8rpx rgba(255, 255, 255, 0.9);
}

.tile.fund::before {
  content: '';
  position: absolute;
  top: 12rpx;
  left: 16rpx;
  right: 16rpx;
  height: 6rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 215, 0, 0.35) 30%,
    rgba(255, 215, 0, 0.5) 50%,
    rgba(255, 215, 0, 0.35) 70%,
    transparent 100%);
  border-radius: 4rpx;
  pointer-events: none;
}

.tile-content {
  text-align: center;
  padding: 12rpx;
  width: 100%;
  position: relative;
}

.tile-icon {
  font-size: 44rpx;
  margin-bottom: 6rpx;
  filter:
    drop-shadow(0 4rpx 6rpx rgba(0, 0, 0, 0.4))
    drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.2));
  text-shadow:
    0 4rpx 8rpx rgba(0, 0, 0, 0.4),
    0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.tile.shop .tile-icon {
  font-size: 44rpx;
  filter:
    drop-shadow(0 6rpx 8rpx rgba(0, 0, 0, 0.5))
    drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.3));
  text-shadow:
    0 4rpx 8rpx rgba(0, 0, 0, 0.4),
    0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.tile-name {
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.95);
  text-shadow:
    0 4rpx 8rpx rgba(0, 0, 0, 0.7),
    0 2rpx 4rpx rgba(0, 0, 0, 0.5),
    0 0 4rpx rgba(0, 0, 0, 0.3);
  word-break: break-all;
  line-height: 1.3;
  letter-spacing: 0.6rpx;
}

.tile-price {
  font-size: 22rpx;
  color: #FFD700;
  margin-top: 6rpx;
  font-weight: 700;
  text-shadow:
    0 4rpx 8rpx rgba(0, 0, 0, 0.6),
    0 2rpx 4rpx rgba(0, 0, 0, 0.4),
    0 0 6rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 1rpx;
}

.tile-level {
  display: flex;
  justify-content: center;
  gap: 4rpx;
  margin-top: 6rpx;
}

.star {
  font-size: 20rpx;
}

.tile-bomb {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  font-size: 32rpx;
  animation: bomb-pulse 1s infinite;
}

@keyframes bomb-pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.8; }
}

.players-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 100;
}

.player-character {
  position: absolute;
  width: 60rpx;
  height: 80rpx;
  transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: auto;
  z-index: 50;
}

.player-character.is-moving {
  animation: bounce 0.6s ease-in-out;
}

.player-character.current-turn .character-body {
  animation: pulse 1.5s ease-in-out infinite;
}

.player-character.has-hall-buff .character-body {
  animation: hall-glow 1.5s ease-in-out infinite;
}

@keyframes hall-glow {
  0%, 100% { box-shadow: 0 0 20rpx 10rpx rgba(77, 208, 225, 0.5), 0 8rpx 16rpx rgba(0, 0, 0, 0.3); }
  50% { box-shadow: 0 0 50rpx 30rpx rgba(77, 208, 225, 0.8), 0 8rpx 16rpx rgba(0, 0, 0, 0.3); }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  25% { transform: translateY(-30rpx) scale(1.1); }
  50% { transform: translateY(-40rpx) scale(1.15); }
  75% { transform: translateY(-20rpx) scale(1.05); }
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7); }
  50% { box-shadow: 0 0 40rpx 20rpx rgba(255, 255, 255, 0.3); }
}

.character-body {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50% 50% 45% 45%;
  position: relative;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.3);
  display: flex;
  justify-content: center;
  align-items: center;
}

.character-face {
  font-size: 32rpx;
  filter: drop-shadow(0 4rpx 4rpx rgba(0, 0, 0, 0.3));
}

.character-shadow {
  position: absolute;
  bottom: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 12rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 50%;
}

.character-name {
  position: absolute;
  bottom: -28rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 14rpx;
  font-weight: bold;
  color: white;
  background: rgba(0, 0, 0, 0.6);
  padding: 2rpx 8rpx;
  border-radius: 12rpx;
  white-space: nowrap;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.skip-turn-indicator {
  position: absolute;
  top: -70rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
  border-radius: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    0 8rpx 24rpx rgba(0, 0, 0, 0.3),
    0 0 40rpx rgba(255, 193, 7, 0.5);
  animation: skip-turn-bounce 1.5s ease-in-out infinite;
  z-index: 10;
  white-space: nowrap;
}

.player-character.in-jail .skip-turn-indicator {
  background: linear-gradient(135deg, #78909c 0%, #546e7a 100%);
  box-shadow:
    0 8rpx 24rpx rgba(0, 0, 0, 0.3),
    0 0 40rpx rgba(120, 144, 156, 0.5);
}

.skip-icon {
  font-size: 28rpx;
  animation: skip-icon-pulse 1s ease-in-out infinite;
}

.skip-text {
  font-size: 18rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

@keyframes skip-turn-bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(-10rpx); }
}

@keyframes skip-icon-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.player-character.in-jail .character-body {
  animation: jail-pulse 1.5s ease-in-out infinite;
}

@keyframes jail-pulse {
  0%, 100% {
    box-shadow:
      0 8rpx 16rpx rgba(0, 0, 0, 0.3),
      0 0 30rpx rgba(120, 144, 156, 0.4);
  }
  50% {
    box-shadow:
      0 8rpx 16rpx rgba(0, 0, 0, 0.3),
      0 0 50rpx rgba(120, 144, 156, 0.7);
  }
}

.bomb-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
  pointer-events: none;
}

.bomb-overlay-content {
  background: linear-gradient(145deg, #2d2d2d 0%, #1a1a1a 50%, #161616 100%);
  border: 4rpx solid #ff4444;
  border-radius: 40rpx;
  padding: 56rpx 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
  box-shadow:
    0 0 60rpx rgba(255, 68, 68, 0.3),
    0 20rpx 80rpx rgba(0, 0, 0, 0.5),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.1);
  animation: bombPopup 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: auto;
}

.bomb-icon {
  font-size: 104rpx;
  animation: bombPulse 0.8s ease-in-out infinite;
  filter: drop-shadow(0 0 30rpx rgba(255, 68, 68, 0.8));
}

.bomb-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #ff6b6b;
  text-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.5);
  letter-spacing: 2rpx;
}

.bomb-message {
  font-size: 28rpx;
  color: #e0e0e0;
  text-align: center;
  line-height: 1.5;
  padding: 0 20rpx;
}

.bomb-cancel-btn {
  margin-top: 16rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  background: linear-gradient(135deg, #4a4a4a 0%, #333333 100%);
  border: 2rpx solid #555555;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.bomb-cancel-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

.select-property-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
  pointer-events: none;
}

.select-property-overlay-content {
  background: linear-gradient(145deg, #2d2d2d 0%, #1a1a1a 50%, #161616 100%);
  border: 4rpx solid #FFD700;
  border-radius: 40rpx;
  padding: 56rpx 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
  box-shadow:
    0 0 60rpx rgba(255, 215, 0, 0.3),
    0 20rpx 80rpx rgba(0, 0, 0, 0.5),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.1);
  animation: selectPropertyPopup 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: auto;
}

.select-property-icon {
  font-size: 104rpx;
  animation: selectPropertyPulse 0.8s ease-in-out infinite;
  filter: drop-shadow(0 0 30rpx rgba(255, 215, 0, 0.8));
}

.select-property-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFD700;
  text-shadow: 0 4rpx 20rpx rgba(255, 215, 0, 0.5);
  letter-spacing: 2rpx;
}

.select-property-message {
  font-size: 28rpx;
  color: #e0e0e0;
  text-align: center;
  line-height: 1.5;
  padding: 0 20rpx;
}

@keyframes selectPropertyPopup {
  0% { opacity: 0; transform: scale(0.5) translateY(40rpx); }
  60% { transform: scale(1.05) translateY(-10rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes selectPropertyPulse {
  0%, 100% { transform: scale(1); filter: drop-shadow(0 0 30rpx rgba(255, 215, 0, 0.8)); }
  50% { transform: scale(1.1); filter: drop-shadow(0 0 50rpx rgba(255, 215, 0, 1)); }
}

@keyframes bombPopup {
  0% { opacity: 0; transform: scale(0.5) translateY(40rpx); }
  60% { transform: scale(1.05) translateY(-10rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes bombPulse {
  0%, 100% { transform: scale(1); filter: drop-shadow(0 0 30rpx rgba(255, 68, 68, 0.8)); }
  50% { transform: scale(1.1); filter: drop-shadow(0 0 50rpx rgba(255, 68, 68, 1)); }
}