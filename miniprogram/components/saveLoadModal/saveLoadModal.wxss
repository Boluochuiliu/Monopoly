.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: linear-gradient(145deg, #2d2d2d 0%, #1a1a1a 100%);
  border-radius: 48rpx;
  padding: 64rpx;
  width: 680rpx;
  max-width: 90vw;
  box-shadow: 0 40rpx 120rpx rgba(0, 0, 0, 0.5);
  border: 4rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  text-align: center;
  margin-bottom: 48rpx;
}

.save-slots {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.save-slot {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  border: 4rpx solid transparent;
}

.save-slot.active {
  border-color: #FFD700;
  background: rgba(255, 215, 0, 0.1);
}

.save-slot.disabled {
  opacity: 0.5;
}

.slot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.slot-name {
  font-weight: 600;
  color: white;
  font-size: 28rpx;
}

.auto-badge {
  padding: 4rpx 16rpx;
  background: rgba(76, 175, 80, 0.2);
  border-radius: 16rpx;
}

.auto-badge text {
  font-size: 20rpx;
  color: #4CAF50;
}

.slot-info {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.slot-time {
  display: block;
  margin-bottom: 8rpx;
}

.slot-details {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.slot-empty text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.3);
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.btn {
  padding: 24rpx 64rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  line-height: 1.2;
}

.btn-primary {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #1a1a2e;
  box-shadow: 0 8rpx 30rpx rgba(255, 215, 0, 0.3);
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}
