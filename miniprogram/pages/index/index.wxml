<view class="page">
  <view class="left">
    <view class="dice-box">
      <text class="dice">🎲</text>
      <view class="ring"></view>
    </view>
    <view class="title">
      <text class="t1">大</text>
      <text class="t2">富</text>
      <text class="t3">翁</text>
    </view>
    <text class="sub">MONOPOLY</text>
    <view class="line"><text>◆</text></view>
    <view class="rules">
      <text class="rules-head">📋 游戏规则</text>
      <view class="r"><text>🎯 掷骰子移动角色</text></view>
      <view class="r"><text>🏠 购买升级地产收租金</text></view>
      <view class="r"><text>🃏 抽取机会卡和命运卡</text></view>
      <view class="r"><text>💰 让对手破产即获胜</text></view>
    </view>
  </view>

  <view class="right">
    <view class="name-input">
      <text class="input-label">👤 你的昵称</text>
      <input class="input-field" placeholder="请输入昵称" value="{{playerName}}" bindinput="onNameInput" />
    </view>

    <view class="btns">
      <button class="btn-primary" bindtap="createRoom">
        <text>🎮 创建房间</text>
      </button>
      
      <button class="btn-secondary" bindtap="toggleRoomIdInput">
        <text>📱 {{showRoomIdInput ? '取消' : '加入房间'}}</text>
      </button>

      <view wx:if="showRoomIdInput" class="room-id-input">
        <input class="room-input" placeholder="输入6位房间号" value="{{roomIdInput}}" bindinput="onRoomIdInput" />
        <button class="btn-join" bindtap="joinRoom">加入</button>
      </view>

      <view class="ai-section">
        <text class="ai-label">🤖 AI 玩家</text>
        <view class="ai-controls">
          <view class="ai-btn" bindtap="decreaseAI"><text>−</text></view>
          <text class="ai-count">{{aiCount}}</text>
          <view class="ai-btn" bindtap="increaseAI"><text>+</text></view>
        </view>
      </view>

      <button class="btn-local" bindtap="startLocalGame">
        <text>💻 单人模式（本地）</text>
      </button>
    </view>
  </view>
</view>