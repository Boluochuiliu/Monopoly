page { width: 100%; height: 100%; overflow: hidden; background: linear-gradient(135deg, #667eea, #764ba2 50%, #f093fb); }

.page { display: flex; width: 100%; height: 100vh; flex-direction: row; overflow: hidden; }

.left { width: 40%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2% 2%; box-sizing: border-box; }

.dice-box { position: relative; margin-bottom: 2%; }
.dice { font-size: 52rpx; display: block; line-height: 1; animation: spin 4s infinite; position: relative; z-index: 2; }
@keyframes spin { 0%,100%{transform:translateY(0) rotate(0)} 25%{transform:translateY(-6rpx) rotate(90deg)} 50%{transform:translateY(0) rotate(180deg)} 75%{transform:translateY(-4rpx) rotate(270deg)} }

.ring { width: 80rpx; height: 80rpx; border: 2rpx solid rgba(255,215,0,.18); border-radius: 50%; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); animation: pulse 3s infinite; }
@keyframes pulse { 0%,100%{transform:translate(-50%,-50%) scale(1);opacity:.5} 50%{transform:translate(-50%,-50%) scale(1.2);opacity:.2} }

.title { display: flex; gap: 4rpx; margin-bottom: 1%; }
.title text { font-size: 36rpx; font-weight: 900; background: linear-gradient(180deg,#fff,#ffd700); background-clip: text; -webkit-background-clip: text; color: transparent; opacity: 0; animation: pop .5s forwards; }
.t1 { animation-delay: 0s !important; }
.t2 { animation-delay: .15s !important; }
.t3 { animation-delay: .3s !important; }
@keyframes pop { from{opacity:0;transform:translateY(-20rpx) scale(0)} to{opacity:1;transform:translateY(0) scale(1)} }

.sub { font-size: 14rpx; letter-spacing: 8rpx; color: rgba(255,215,0,.55); font-weight: 600; margin: 1% 0 2%; }

.line { margin-bottom: 2%; }
.line text { color: rgba(255,215,0,.35); font-size: 12rpx; }

.rules { width: 88%; background: rgba(0,0,0,.12); border-radius: 16rpx; padding: 3% 4%; border: 2rpx solid rgba(255,255,255,.05); flex: 1; min-height: 0; max-height: 45vh; overflow-y: auto; box-sizing: border-box; }
.rules-head { font-size: 17rpx; font-weight: 700; color: rgba(255,215,0,.75); display: block; margin-bottom: 3%; }
.r { padding: 2% 0; font-size: 15rpx; color: rgba(255,255,255,.68); border-bottom: 1rpx solid rgba(255,255,255,.03); line-height: 1.35; }
.r:last-child { border-bottom: none; }

.right { width: 60%; height: 100%; display: flex; flex-direction: column; padding: 2% 3%; box-sizing: border-box; gap: 3%; overflow: hidden; }

.name-input { background: rgba(255,255,255,.04); border: 2rpx solid rgba(255,255,255,.06); border-radius: 18rpx; padding: 3% 4%; }
.input-label { font-size: 18rpx; font-weight: 600; color: rgba(255,255,255,.65); display: block; margin-bottom: 2%; }
.input-field { width: 100%; background: rgba(255,255,255,.03); border: 2rpx solid rgba(255,255,255,.08); border-radius: 12rpx; padding: 3% 4%; font-size: 20rpx; color: #fff; box-sizing: border-box; }
.input-field::placeholder { color: rgba(255,255,255,.3); }

.btns { flex: 1; display: flex; flex-direction: column; gap: 2%; overflow-y: auto; }

.btn-primary { flex-shrink: 0; padding: 3% 4%; border-radius: 18rpx; border: none; background: linear-gradient(135deg,#43a047,#2e7d32,#1b5e20); color: #fff; font-size: 24rpx; font-weight: 700; box-shadow: 0 4rpx 16rpx rgba(46,125,50,.28); }
.btn-primary::after { border: none; }
.btn-primary:active { transform: scale(.97); }

.btn-secondary { flex-shrink: 0; padding: 3% 4%; border-radius: 18rpx; border: 2rpx solid rgba(255,255,255,.12); background: rgba(255,255,255,.04); color: rgba(255,255,255,.7); font-size: 22rpx; }
.btn-secondary::after { border: none; }
.btn-secondary:active { background: rgba(255,255,255,.08); }

.room-id-input { flex-shrink: 0; display: flex; gap: 2%; }
.room-input { flex: 1; background: rgba(255,255,255,.03); border: 2rpx solid rgba(255,255,255,.08); border-radius: 12rpx; padding: 3% 4%; font-size: 20rpx; color: #fff; text-align: center; }
.room-input::placeholder { color: rgba(255,255,255,.3); }
.btn-join { padding: 3% 6%; border-radius: 12rpx; border: none; background: linear-gradient(135deg,#667eea,#764ba2); color: #fff; font-size: 20rpx; font-weight: 600; }
.btn-join::after { border: none; }

.ai-section { flex-shrink: 0; display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,.03); border: 2rpx solid rgba(255,255,255,.05); border-radius: 16rpx; padding: 3% 4%; }
.ai-label { font-size: 20rpx; color: rgba(255,255,255,.65); }
.ai-controls { display: flex; align-items: center; gap: 12rpx; }
.ai-btn { width: 40rpx; height: 40rpx; border-radius: 10rpx; border: 2rpx solid rgba(255,255,255,.12); background: rgba(255,255,255,.05); display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: rgba(255,255,255,.55); }
.ai-btn:active { background: rgba(255,255,255,.1); }
.ai-count { font-size: 24rpx; font-weight: 700; color: #fff; min-width: 30rpx; text-align: center; }

.btn-local { flex-shrink: 0; padding: 3% 4%; border-radius: 18rpx; border: 2rpx solid rgba(255,255,255,.08); background: rgba(255,255,255,.02); color: rgba(255,255,255,.45); font-size: 20rpx; }
.btn-local::after { border: none; }
.btn-local:active { background: rgba(255,255,255,.05); }